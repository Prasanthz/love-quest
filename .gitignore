@"
# ───────────────────────────────────────────────
#  Love Quest — .gitignore
# ───────────────────────────────────────────────

# Optional sound files (often large / copyrighted)
assets/sounds/*.mp3
assets/sounds/*.wav
assets/sounds/*.ogg

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
"@ | Set-Content -Encoding utf8 .gitignore